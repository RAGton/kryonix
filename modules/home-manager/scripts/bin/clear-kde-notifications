#!/usr/bin/env bash

# =============================================================================
# Autor: rag
#
# O que é:
# - Script para limpar/fechar todas as notificações do KDE Plasma.
#
# Por quê:
# - Ajuda a “resetar” o centro de notificações quando acumula muita coisa.
#
# Como:
# - Cria uma notificação efêmera para obter um ID alto (`notify-send -p`).
# - Itera de forma decrescente e chama `org.freedesktop.Notifications.CloseNotification` via `qdbus`.
#
# Riscos:
# - Depende de `notify-send` e `qdbus`.
# - Fecha notificações indiscriminadamente (inclusive as que você queria manter).
# =============================================================================
# Script para limpar todas as notificações do KDE Plasma.

for i in $(seq "$(notify-send -p " " -t 1)" -1 0); do
	qdbus org.kde.plasmashell /org/freedesktop/Notifications org.freedesktop.Notifications.CloseNotification "$i"
done
