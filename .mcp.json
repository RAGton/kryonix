{
  "mcpServers": {
    "kryonix-brain": {
      "command": "/run/current-system/sw/bin/uv",
      "args": [
        "--quiet",
        "run",
        "--project",
        "/etc/kryonix/packages/kryonix-brain-lightrag",
        "kg-server"
      ],
      "cwd": "/etc/kryonix"
    },
    "mcp-nixos": {
      "command": "/run/current-system/sw/bin/uvx",
      "args": [
        "mcp-nixos"
      ]
    },
    "vault-readonly": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/rocha/.local/share/kryonix/kryonix-vault"
      ],
      "description": "Read-only access to Obsidian vault"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "description": "GitHub issues, PRs, commits, file access"
    }
  }
}